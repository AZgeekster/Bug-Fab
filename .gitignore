# --- Bug-Fab runtime artifacts ---
# Local storage directories created by example apps and dev runs.
#
# `bug_reports/` (underscore) is the storage-dir name; leaving it unanchored is
# safe because no source directory uses that name.
#
# The hyphenated variant is NOT a storage-dir name -- `bug-reports` is the
# protocol's URL segment, so unanchored it excluded route directories such as
# `examples/nextjs-minimal/src/app/api/bug-reports/`. Anchored to the root.
/bug-reports/
bug_reports/
.bug-fab-storage/
*.db
*.sqlite
*.sqlite3

# Django example's MEDIA_ROOT — populated at runtime; never tracked.
examples/django-minimal/media/

# --- .NET build artifacts (ASP.NET adapter) ---
adapters/aspnet/**/bin/
adapters/aspnet/**/obj/
adapters/aspnet/.vs/
*.user

# --- Co-hosted marketing site ---
# Populated by `cp -r ../SITE-BUG-FAB/dist marketing-dist` before
# `flyctl deploy`. Never committed — built fresh per deploy. The .gitkeep
# stays tracked so the Dockerfile's COPY succeeds on a clean clone (the
# runtime falls back to the playground page when index.html is absent).
marketing-dist/*
!marketing-dist/.gitkeep
