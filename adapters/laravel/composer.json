{
    "name": "bugfab/laravel-adapter",
    "description": "Bug-Fab v0.1 wire-protocol adapter for Laravel 11.x. Drop-in bug reporter for any Laravel app.",
    "keywords": ["bug-fab", "bug-report", "laravel", "feedback", "screenshot", "diagnostics"],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0",
        "illuminate/support": "^11.0",
        "illuminate/http": "^11.0",
        "illuminate/database": "^11.0",
        "illuminate/routing": "^11.0",
        "illuminate/validation": "^11.0",
        "illuminate/filesystem": "^11.0",
        "illuminate/cache": "^11.0",
        "illuminate/console": "^11.0",
        "illuminate/view": "^11.0",
        "symfony/http-foundation": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "BugFab\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BugFab\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BugFab\\Laravel\\BugFabServiceProvider"
            ],
            "aliases": {}
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
