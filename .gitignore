# Anchored to the repo root. Unanchored, `lib/` matches at ANY depth, which
# silently excluded `adapters/rails/lib/`, `adapters/phoenix/lib/`, and every
# `src/lib/` in the JS adapters and examples -- two entire first-party
# adapters were absent from the published repo.
/lib/
/lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST

