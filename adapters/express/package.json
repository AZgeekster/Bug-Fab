{
  "name": "bug-fab-express",
  "version": "0.1.0",
  "description": "Express adapter for the Bug-Fab wire protocol (v0.1).",
  "keywords": [
    "bug-fab",
    "bug-report",
    "express",
    "middleware",
    "adapter"
  ],
  "license": "MIT",
  "author": "AZgeekster",
  "homepage": "https://github.com/AZgeekster/Bug-Fab",
  "repository": {
    "type": "git",
    "url": "https://github.com/AZgeekster/Bug-Fab.git",
    "directory": "adapters/express"
  },
  "bugs": {
    "url": "https://github.com/AZgeekster/Bug-Fab/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./storage/file": {
      "types": "./dist/storage/FileStorage.d.ts",
      "import": "./dist/storage/FileStorage.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "express": ">=4.18.0",
    "multer": ">=2.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.4.0",
    "express": "^4.18.2",
    "multer": "^2.0.0",
    "supertest": "^6.3.4",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
