# Bug-Fab Next.js minimal POC — environment variables.
#
# Copy to `.env.local` for local dev. Next.js loads `.env.local`
# automatically; nothing else is required.

# --------------------------------------------------------------------------
# Storage location for submitted reports.
# --------------------------------------------------------------------------
# Path is resolved relative to the project root (where package.json lives).
# Defaults to `./bug_reports` when unset.
BUG_FAB_STORAGE_DIR=./bug_reports

# Optional ID prefix — emitted IDs become `bug-{PREFIX}NNN` instead of
# `bug-NNN`. Useful for multi-environment shared collectors (e.g. "P" for
# prod, "D" for dev). The protocol regex is `^bug-[A-Za-z]?\d{3,}$`.
# BUG_FAB_ID_PREFIX=

# --------------------------------------------------------------------------
# Viewer auth — placeholder only. The POC compares an `x-admin-token`
# request header to this value to gate /admin/bug-reports/* routes.
# Production deployments MUST replace this with a real auth solution
# (NextAuth.js, Clerk, your own session middleware, etc.).
# --------------------------------------------------------------------------
ADMIN_TOKEN=dev-token-change-me
