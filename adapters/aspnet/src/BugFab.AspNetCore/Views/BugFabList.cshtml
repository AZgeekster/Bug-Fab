@*
    Optional Razor list view. See _BugFabLayout.cshtml for the wire-up notes.
    The model is `BugFab.AspNetCore.Endpoints.BugFabListViewModel` (sketch —
    consumers building this path supply their own view model that includes
    items + total + stats).

    The full upstream Jinja2 list page is at:
    https://github.com/AZgeekster/Bug-Fab/blob/main/bug_fab/templates/list.html
*@
@model BugFab.AspNetCore.Endpoints.BugFabListViewModel
@{
    ViewBag.Title = "Bug Reports";
    Layout = "_BugFabLayout";
}

<h2>Bug Reports</h2>

<section class="stats">
    @foreach (var (key, value) in Model.Stats)
    {
        <div class="stat">
            <span class="label">@key</span>
            <span class="value">@value</span>
        </div>
    }
</section>

<p class="count">@Model.Total reports total</p>

<table class="reports">
    <thead>
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Severity</th>
            <th>Status</th>
            <th>Module</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td><a href="@(Url.RouteUrl("BugFab_HtmlDetail", new { id = item.Id }) ?? $"./{item.Id}")">@item.Id</a></td>
                <td>@item.Title</td>
                <td><span class="severity severity-@item.Severity">@item.Severity</span></td>
                <td><span class="status status-@item.Status">@item.Status</span></td>
                <td>@item.Module</td>
                <td>@item.CreatedAt</td>
            </tr>
        }
    </tbody>
</table>
