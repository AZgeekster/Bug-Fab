# EditorConfig — https://editorconfig.org
#
# Top-level config so editors apply consistent indentation and line
# endings across contributors regardless of OS or editor.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Python — PEP 8 / Black-compatible 4-space indent.
[*.py]
indent_size = 4
max_line_length = 100

# JavaScript / TypeScript / JSON — 2-space.
[*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc}]
indent_size = 2

# YAML / TOML — 2-space.
[*.{yml,yaml,toml}]
indent_size = 2

# HTML / CSS / SVG — 2-space.
[*.{html,htm,css,scss,svg}]
indent_size = 2

# Markdown — 2-space, allow trailing whitespace (line breaks).
[*.{md,markdown}]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 80

# Makefile — tabs are mandatory.
[Makefile]
indent_style = tab

# Vendored assets — leave them alone.
[static/vendor/**]
indent_style = unset
indent_size = unset
end_of_line = unset
trim_trailing_whitespace = false
insert_final_newline = false
